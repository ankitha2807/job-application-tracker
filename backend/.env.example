# Backend Environment Variables (Local Development)
# Copy this to .env and fill in your values

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_here_at_least_32_chars

# Database Configuration (for local MySQL)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/job_tracker
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_password

# Or use H2 (in-memory, default):
# SPRING_DATASOURCE_URL=jdbc:h2:mem:job_tracker;DB_CLOSE_DELAY=-1
# SPRING_DATASOURCE_USERNAME=sa
# SPRING_DATASOURCE_PASSWORD=
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.h2.Driver

# Server Port
PORT=8080
